{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.Extensions.Http": "Warning",
      "Phipes.Assistant.DdnsWorker": "Information"
    }
  },
  "Ddns": {
    "PollIntervalSeconds": 300,
    "Cloudflare": {
      "ApiTokenPath": "REPLACE_WITH_PATH_TO_YOUR_CLOUDFLARE_TOKEN_XML",
      "Records": []
    },
    "Unifi": {
      "BaseUrl": "https://REPLACE_WITH_YOUR_UDM_HOST",
      "ApiTokenPath": "REPLACE_WITH_PATH_TO_YOUR_UDM_TOKEN_XML",
      "SiteName": "default",
      "VerifyTls": false,
      "TimeoutSeconds": 10
    },
    "Ipify": {
      "Endpoint": "https://api.ipify.org?format=text",
      "TimeoutSeconds": 10
    }
  }
}
