<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Configuración NuGet local del repositorio.
    <clear /> descarta los feeds heredados de NuGet.config del usuario o de la máquina
    (incluido cualquier feed privado interno), para que el build sea reproducible para
    cualquiera que clone este repositorio sin requerir credenciales privadas.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
